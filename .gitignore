# Exclude everything by default
*

# Allow specific root-level files
!.gitignore
!.gitattributes
!README.md
!CHANGELOG.md
!changelog.md
!build.bat
!build_dll.bat
!prepend_changelog.py
!release.bat
!fill_the_pane.spec
!ftp_loop.cpp
!feature list.txt
!.github/
!.github/**

# Allow assets folder (sample result media for README)
!assets/
!assets/**

# Explicitly exclude build artifacts that may already be tracked
build/
code/
dist/
*.dll
*.log
*.txt
*.exe
